# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and will never be committed.

# Anthropic API key — used for blueprint generation and overview AI
# Get one at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used for Journey Map image generation (DALL-E 3)
# Optional: the app runs without it; Journey Map image generation will be disabled.
# Get one at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-...
