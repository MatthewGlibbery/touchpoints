# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and will never be committed.

# Supabase — required for auth and cloud storage
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI keys are now Supabase secrets (server-side only).
# Set them via the Supabase dashboard (Settings → Edge Functions → Secrets)
# or with the CLI: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#                  supabase secrets set OPENAI_API_KEY=sk-proj-...
